<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title || 'Server error – Honest Auto' %></title>
        <link rel="stylesheet" href="/css/style.css" />
    </head>
    <body>
        <div class="ha-app">
            <header class="ha-header">
                <div class="ha-header-inner">
                    <%- include('../partials/header') %>
                    <%- include('../partials/nav') %>
                </div>
            </header>

            <main class="ha-main">
                <section class="ha-flash-region">
                    <%- include('../partials/flash') %>
                </section>

                <section class="ha-page ha-page-error">
                    <div class="ha-page-inner">
                        <h1 class="ha-page-title">Something went wrong on our end.</h1>
                        <p class="ha-page-body">
                            An unexpected error occurred while processing your request. Please try again in a
                            moment.
                        </p>

                        <% if (NODE_ENV !== 'production' && (error || stack)) { %>
                        <div class="ha-error-debug">
                            <% if (error) { %>
                            <p><strong>Error:</strong> <%= error %></p>
                            <% } %>
                            <% if (stack) { %>
                            <pre class="ha-error-stack"><%= stack %></pre>
                            <% } %>
                        </div>
                        <% } %>

                        <div class="ha-page-actions">
                            <a href="/" class="ha-button ha-button-primary">Return to home</a>
                        </div>
                    </div>
                </section>
            </main>

            <footer class="ha-footer">
                <div class="ha-footer-inner">
                    <%- include('../partials/footer') %>
                </div>
            </footer>
        </div>
    </body>
</html>

