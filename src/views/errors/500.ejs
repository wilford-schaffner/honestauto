<%- include('../layouts/app-start') %>
                <section class="ha-page ha-page-error">
                    <div class="ha-page-inner">
                        <h1 class="ha-page-title">Something Went Wrong on Our End.</h1>
                        <p class="ha-page-body">
                            An unexpected error occurred while processing your request. Please try again in a
                            moment.
                        </p>

                        <% if (NODE_ENV !== 'production' && (debugError || stack)) { %>
                        <div class="ha-error-debug">
                            <% if (debugError) { %>
                            <p><strong>Error:</strong> <%= debugError %></p>
                            <% } %>
                            <% if (stack) { %>
                            <pre class="ha-error-stack"><%= stack %></pre>
                            <% } %>
                        </div>
                        <% } %>

                        <div class="ha-page-actions">
                            <a href="/" class="ha-button ha-button-primary">Return to Home</a>
                        </div>
                    </div>
                </section>
<%- include('../layouts/app-main-footer') %>
<%- include('../layouts/app-doc-end') %>
