<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title || 'Page not found – Honest Auto' %></title>
        <link rel="stylesheet" href="/css/style.css" />
    </head>
    <body>
        <div class="ha-app">
            <header class="ha-header">
                <div class="ha-header-inner">
                    <%- include('../partials/header') %>
                    <%- include('../partials/nav') %>
                </div>
            </header>

            <main class="ha-main">
                <section class="ha-flash-region">
                    <%- include('../partials/flash') %>
                </section>

                <section class="ha-page ha-page-error">
                    <div class="ha-page-inner">
                        <h1 class="ha-page-title">We couldn’t find that page.</h1>
                        <p class="ha-page-body">
                            The link you followed may be broken, or the page may have been moved.
                        </p>
                        <div class="ha-page-actions">
                            <a href="/" class="ha-button ha-button-primary">Go to home</a>
                            <a href="/vehicles" class="ha-button ha-button-ghost">Browse vehicles</a>
                        </div>
                    </div>
                </section>
            </main>

            <footer class="ha-footer">
                <div class="ha-footer-inner">
                    <%- include('../partials/footer') %>
                </div>
            </footer>
        </div>
    </body>
</html>

