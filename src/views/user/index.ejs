<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title || 'Your account – Honest Auto' %></title>
        <link rel="stylesheet" href="/css/style.css" />
    </head>
    <body>
        <div class="ha-app">
            <header class="ha-header">
                <div class="ha-header-inner">
                    <%- include('../partials/header') %>
                    <%- include('../partials/nav') %>
                </div>
            </header>

            <main class="ha-main">
                <section class="ha-flash-region">
                    <%- include('../partials/flash') %>
                </section>

                <section class="ha-page">
                    <div class="ha-page-inner">
                        <div class="ha-page-heading">
                            <div>
                                <h1 class="ha-page-title">Your dashboard</h1>
                                <p class="ha-page-body">
                                    Track service requests, view status updates, and submit new requests for your vehicles.
                                </p>
                            </div>
                        </div>

                        <div class="ha-page-actions">
                            <a href="/user/service-requests" class="ha-button ha-button-primary"
                                >Your service requests</a
                            >
                            <a href="/user/service-requests/new" class="ha-button ha-button-ghost"
                                >New service request</a
                            >
                        </div>
                    </div>
                </section>
            </main>

            <footer class="ha-footer">
                <div class="ha-footer-inner">
                    <%- include('../partials/footer') %>
                </div>
            </footer>
        </div>
    </body>
</html>
