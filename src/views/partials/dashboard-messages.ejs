<section class="ha-dashboard-messages">
    <% const msgs = contactMessages || []; %>
    <% const unresolvedCount = msgs.filter(function (m) { return !m.resolved; }).length; %>
    <div class="ha-dashboard-messages-head">
        <h2 class="ha-page-title">Messages</h2>
        <span class="ha-dashboard-messages-unresolved"><%= unresolvedCount %> unresolved</span>
    </div>
    <% if (!msgs.length) { %>
        <div class="ha-empty ha-dashboard-messages-empty">
            <h3 class="ha-empty-title">No Messages Yet.</h3>
        </div>
    <% } else { %>
        <ul class="ha-review-list ha-dashboard-messages-list">
            <% msgs.forEach((message) => { %>
                <li class="ha-review-item ha-dashboard-message-item">
                    <div class="ha-dashboard-message-top">
                        <div class="ha-review-item-header">
                            <span class="ha-review-author"><%= message.subject %></span>
                            <span class="ha-review-meta"><%= new Date(message.submitted).toLocaleString() %></span>
                        </div>
                        <form
                            method="post"
                            action="<%= contactMessagesActionBase %>/contact-messages/<%= message.id %>/toggle-resolved"
                            class="ha-inline-form ha-dashboard-message-action"
                        >
                            <button
                                type="submit"
                                class="ha-button ha-button-sm <%= message.resolved ? 'ha-button-resolved-toggle' : 'ha-button-ghost' %>"
                            >
                                <%= message.resolved ? 'Resolved' : 'Resolve' %>
                            </button>
                        </form>
                    </div>
                    <p class="ha-review-meta"><%= message.name %> • <%= message.email %></p>
                    <p class="ha-review-body"><%= message.message %></p>
                </li>
            <% }) %>
        </ul>
    <% } %>
</section>
