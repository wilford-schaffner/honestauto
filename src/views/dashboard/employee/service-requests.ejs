<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title || 'Service requests – Honest Auto' %></title>
        <link rel="stylesheet" href="/css/style.css" />
    </head>
    <body>
        <div class="ha-app">
            <header class="ha-header">
                <div class="ha-header-inner">
                    <%- include('../../partials/header') %>
                    <%- include('../../partials/nav') %>
                </div>
            </header>
            <main class="ha-main">
                <section class="ha-flash-region"><%- include('../../partials/flash') %></section>
                <section class="ha-page">
                    <div class="ha-page-inner">
                        <div class="ha-page-heading ha-page-heading-inline">
                            <div>
                                <h1 class="ha-page-title">Service requests</h1>
                                <% if (ownerListControls) { %>
                                    <p class="ha-page-body">
                                        <% if (showCompleted) { %>
                                            Showing all requests, including completed. Sort and filters apply below.
                                        <% } else { %>
                                            Completed requests are hidden. Use “Show completed” to include them.
                                        <% } %>
                                    </p>
                                <% } else { %>
                                    <p class="ha-page-body">Open requests are shown first to keep active work prioritized.</p>
                                <% } %>
                            </div>
                            <% if (ownerListControls) { %>
                                <div class="ha-page-actions" style="flex-wrap: wrap; justify-content: flex-end; align-items: center;">
                                    <a href="/dashboard/owner" class="ha-button ha-button-ghost">Back</a>
                                    <% if (showCompleted) { %>
                                        <a
                                            href="/dashboard/employee/service-requests?sort=<%= ownerSortKey %>"
                                            class="ha-button ha-button-ghost"
                                            >Hide completed</a
                                        >
                                    <% } else { %>
                                        <a
                                            href="/dashboard/employee/service-requests?sort=<%= ownerSortKey %>&amp;showCompleted=1"
                                            class="ha-button ha-button-ghost"
                                            >Show completed</a
                                        >
                                    <% } %>
                                    <form method="get" action="/dashboard/employee/service-requests" class="ha-inline-form" style="display: inline-flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;">
                                        <% if (showCompleted) { %>
                                            <input type="hidden" name="showCompleted" value="1" />
                                        <% } %>
                                        <label class="ha-label" for="owner-service-sort" style="margin: 0;">Sort</label>
                                        <select
                                            id="owner-service-sort"
                                            name="sort"
                                            class="ha-input"
                                            style="width: auto; min-width: 11rem;"
                                            onchange="this.form.submit()"
                                        >
                                            <option value="status" <%= ownerSortKey === 'status' ? 'selected' : '' %>>Status</option>
                                            <option value="id" <%= ownerSortKey === 'id' ? 'selected' : '' %>>Service Number</option>
                                            <option value="name" <%= ownerSortKey === 'name' ? 'selected' : '' %>>Name</option>
                                            <option value="vehicle" <%= ownerSortKey === 'vehicle' ? 'selected' : '' %>>Vehicle</option>
                                        </select>
                                    </form>
                                </div>
                            <% } else { %>
                                <div class="ha-page-actions">
                                    <a href="/dashboard/employee" class="ha-button ha-button-ghost">Back</a>
                                </div>
                            <% } %>
                        </div>
                        <% if (!requests || requests.length === 0) { %>
                            <div class="ha-empty"><h3 class="ha-empty-title">No service requests found.</h3></div>
                        <% } else { %>
                            <ul class="ha-service-request-grid">
                                <% requests.forEach((request) => { %>
                                    <% const statusClass = request.status === 'completed' ? 'ha-status-pill-completed' : request.status === 'in_progress' ? 'ha-status-pill-in-progress' : 'ha-status-pill-submitted'; %>
                                    <li class="ha-service-request-card">
                                        <a href="/dashboard/employee/service-requests/<%= request.id %>" class="ha-service-request-link">
                                            <div class="ha-service-request-header">
                                                <span class="ha-status-pill <%= statusClass %>"><%= request.status_label %></span>
                                                <span class="ha-review-meta">#<%= request.id %></span>
                                            </div>
                                            <h3 class="ha-service-request-title"><%= request.title || `Request #${request.id}` %></h3>
                                            <p class="ha-service-request-description">
                                                <strong><%= request.user?.name %></strong>
                                                <% if (request.vehicle) { %>
                                                    <span class="ha-meta-sep">•</span>
                                                    <%= request.vehicle.year %> <%= request.vehicle.make %> <%= request.vehicle.model %>
                                                <% } %>
                                            </p>
                                        </a>
                                    </li>
                                <% }) %>
                            </ul>
                        <% } %>
                    </div>
                </section>
            </main>
            <footer class="ha-footer">
                <div class="ha-footer-inner"><%- include('../../partials/footer') %></div>
            </footer>
        </div>
    </body>
</html>
