<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title || 'Reviews – Honest Auto' %></title>
        <link rel="stylesheet" href="/css/style.css" />
    </head>
    <body>
        <div class="ha-app">
            <header class="ha-header">
                <div class="ha-header-inner">
                    <%- include('../../partials/header') %>
                    <%- include('../../partials/nav') %>
                </div>
            </header>

            <main class="ha-main">
                <section class="ha-flash-region">
                    <%- include('../../partials/flash') %>
                </section>

                <section class="ha-page">
                    <div class="ha-page-inner">
                        <h1 class="ha-page-title">Reviews</h1>
                        <p class="ha-panel-body">
                            Remove inappropriate reviews from each vehicle’s detail page using the Remove control next to
                            the review. A fuller moderation list will be added to this dashboard in a later update.
                        </p>
                    </div>
                </section>
            </main>

            <footer class="ha-footer">
                <div class="ha-footer-inner">
                    <%- include('../../partials/footer') %>
                </div>
            </footer>
        </div>
    </body>
</html>
