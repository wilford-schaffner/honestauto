<%- include('../layouts/app-start') %>
                <section class="ha-page">
                    <div class="ha-page-inner">
                        <h1 class="ha-page-title">Log In to Your Account</h1>
                        <p class="ha-page-body">
                            Access your dashboard, vehicle reviews, and service requests.
                        </p>

                        <form method="post" action="/auth/login" class="ha-form" novalidate>
                            <div class="ha-field">
                                <label class="ha-label" for="email">Email</label>
                                <input
                                    class="ha-input <%= fieldErrors?.email ? 'ha-input-error' : '' %>"
                                    type="email"
                                    id="email"
                                    name="email"
                                    value="<%= form?.email || '' %>"
                                    autocomplete="email"
                                    required
                                />
                                <% if (fieldErrors?.email) { %>
                                    <p class="ha-field-error"><%= fieldErrors.email %></p>
                                <% } %>
                            </div>

                            <div class="ha-field">
                                <label class="ha-label" for="password">Password</label>
                                <input
                                    class="ha-input <%= fieldErrors?.password ? 'ha-input-error' : '' %>"
                                    type="password"
                                    id="password"
                                    name="password"
                                    autocomplete="current-password"
                                    required
                                />
                                <% if (fieldErrors?.password) { %>
                                    <p class="ha-field-error"><%= fieldErrors.password %></p>
                                <% } %>
                            </div>

                            <% if (error) { %>
                                <p class="ha-field-error"><%= error %></p>
                            <% } %>

                            <div class="ha-page-actions">
                                <button type="submit" class="ha-button ha-button-primary">Log In</button>
                                <a href="/auth/register" class="ha-button ha-button-ghost">Create Account</a>
                            </div>
                        </form>
                    </div>
                </section>
<%- include('../layouts/app-main-footer') %>
<%- include('../layouts/app-doc-end') %>
