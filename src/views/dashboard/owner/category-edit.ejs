<%- include('../../layouts/app-start') %>
                <section class="ha-page">
                    <div class="ha-page-inner">
                        <h1 class="ha-page-title">Edit Category</h1>
                        <% if (error) { %><p class="ha-field-error"><%= error %></p><% } %>
                        <form method="post" action="/dashboard/owner/categories/<%= category.id %>" class="ha-form">
                            <div class="ha-field">
                                <label class="ha-label" for="name">Category name</label>
                                <input id="name" name="name" class="ha-input <%= fieldErrors.name ? 'ha-input-error' : '' %>" value="<%= form.name %>" />
                                <% if (fieldErrors.name) { %><p class="ha-field-error"><%= fieldErrors.name %></p><% } %>
                            </div>
                            <div class="ha-page-actions">
                                <button type="submit" class="ha-button ha-button-primary">Save</button>
                                <a href="/dashboard/owner/categories" class="ha-button ha-button-ghost">Cancel</a>
                            </div>
                        </form>
                    </div>
                </section>
<%- include('../../layouts/app-main-footer') %>
<%- include('../../layouts/app-doc-end') %>
