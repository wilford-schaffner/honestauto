<%- include('../layouts/app-start') %>
                <section class="ha-hero">
                    <div class="ha-hero-content">
                        <h1 class="ha-hero-title">Honest cars. Honest service.</h1>
                        <p class="ha-hero-subtitle">
                            Browse a curated inventory of used vehicles, read reviews from real drivers, and
                            manage service requests for your car — all from a single, straightforward dashboard.
                        </p>

                        <div class="ha-hero-actions">
                            <a href="/vehicles" class="ha-button ha-button-primary">
                                Browse Vehicles
                            </a>
                            <a href="/auth/register" class="ha-button ha-button-ghost">
                                Create an Account
                            </a>
                        </div>

                        <div class="ha-hero-highlights">
                            <div class="ha-highlight">
                                <h2 class="ha-highlight-title">For Shoppers</h2>
                                <p class="ha-highlight-body">
                                    Explore inventory by category, view detailed specs and pricing, and see what
                                    other drivers think before you visit the lot.
                                </p>
                            </div>
                            <div class="ha-highlight">
                                <h2 class="ha-highlight-title">For Owners</h2>
                                <p class="ha-highlight-body">
                                    Submit and track service requests, leave reviews on your vehicle, and keep a
                                    history of the work done on your car.
                                </p>
                            </div>
                            <div class="ha-highlight">
                                <h2 class="ha-highlight-title">For Staff</h2>
                                <p class="ha-highlight-body">
                                    Manage inventory, reviews, contact messages, and service workflows from a
                                    focused employee and owner dashboard.
                                </p>
                            </div>
                        </div>

                        <div class="ha-home-featured">
                            <div class="ha-page-heading ha-page-heading-inline">
                                <div>
                                    <h2 class="ha-section-title">Featured Vehicles</h2>
                                    <p class="ha-section-body">A quick look at what just arrived.</p>
                                </div>
                                <a href="/vehicles" class="ha-button ha-button-ghost">Browse All</a>
                            </div>

                            <% if (!featuredVehicles || featuredVehicles.length === 0) { %>
                                <div class="ha-empty">
                                    <h3 class="ha-empty-title">No Featured Vehicles Yet.</h3>
                                    <p class="ha-empty-body">Check back soon, or browse the full inventory.</p>
                                </div>
                            <% } else { %>
                                <div class="ha-vehicle-grid ha-vehicle-grid-compact">
                                    <% featuredVehicles.forEach((vehicle) => { %>
                                        <article class="ha-card">
                                            <a href="/vehicles/<%= vehicle.id %>" class="ha-card-link">
                                                <div class="ha-card-media">
                                                    <% if (vehicle.primaryImage && vehicle.primaryImage.url) { %>
                                                        <img
                                                            class="ha-card-image"
                                                            src="<%= vehicle.primaryImage.url %>"
                                                            alt="<%= `${vehicle.year} ${vehicle.make} ${vehicle.model}` %>"
                                                            loading="lazy"
                                                        />
                                                    <% } else { %>
                                                        <div class="ha-card-image ha-card-image-placeholder">
                                                            No image
                                                        </div>
                                                    <% } %>
                                                    <div class="ha-card-badge"><%= vehicle.category?.name %></div>
                                                </div>
                                                <div class="ha-card-body">
                                                    <h3 class="ha-card-title">
                                                        <%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %>
                                                    </h3>
                                                    <p class="ha-card-price">
                                                        $<%= Number(vehicle.price).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                                                    </p>
                                                </div>
                                            </a>
                                        </article>
                                    <% }); %>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </section>
<%- include('../layouts/app-main-footer') %>
<%- include('../layouts/app-doc-end') %>
