<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title || 'Vehicle – Honest Auto' %></title>
        <link rel="stylesheet" href="/css/style.css" />
    </head>
    <body>
        <div class="ha-app">
            <header class="ha-header">
                <div class="ha-header-inner">
                    <%- include('../partials/header') %>
                    <%- include('../partials/nav') %>
                </div>
            </header>

            <main class="ha-main">
                <section class="ha-flash-region">
                    <%- include('../partials/flash') %>
                </section>

                <section class="ha-page">
                    <div class="ha-page-inner">
                        <div class="ha-detail-header">
                            <div>
                                <p class="ha-detail-kicker"><%= vehicle.category?.name %></p>
                                <h1 class="ha-page-title">
                                    <%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %>
                                </h1>
                                <p class="ha-detail-subtitle">
                                    <% if (vehicle.mileage !== null && vehicle.mileage !== undefined) { %>
                                        <span><%= Number(vehicle.mileage).toLocaleString() %> miles</span>
                                        <span class="ha-meta-sep">•</span>
                                    <% } %>
                                    <span class="<%= vehicle.available ? 'ha-status-available' : 'ha-status-unavailable' %>">
                                        <%= vehicle.available ? 'Available now' : 'Currently unavailable' %>
                                    </span>
                                </p>
                            </div>
                            <div class="ha-detail-price">
                                <span class="ha-detail-price-label">Price</span>
                                <span class="ha-detail-price-value">
                                    $<%= Number(vehicle.price).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                                </span>
                                <a href="/contact" class="ha-button ha-button-primary">Contact about this vehicle</a>
                                <% if (currentUser) { %>
                                    <a
                                        href="/user/service-requests/new?vehicleId=<%= vehicle.id %>"
                                        class="ha-button ha-button-ghost"
                                    >Request service</a>
                                <% } %>
                            </div>
                        </div>

                        <div class="ha-detail-grid">
                            <section class="ha-detail-gallery">
                                <% if (vehicle.images && vehicle.images.length) { %>
                                    <div class="ha-gallery">
                                        <% vehicle.images.forEach((img, idx) => { %>
                                            <figure class="ha-gallery-item <%= idx === 0 ? 'ha-gallery-item-primary' : '' %>">
                                                <img
                                                    class="ha-gallery-image"
                                                    src="<%= img.url %>"
                                                    alt="<%= img.caption || `${vehicle.year} ${vehicle.make} ${vehicle.model}` %>"
                                                    loading="<%= idx === 0 ? 'eager' : 'lazy' %>"
                                                />
                                                <% if (img.caption) { %>
                                                    <figcaption class="ha-gallery-caption"><%= img.caption %></figcaption>
                                                <% } %>
                                            </figure>
                                        <% }); %>
                                    </div>
                                <% } else { %>
                                    <div class="ha-gallery-placeholder">No images available for this vehicle yet.</div>
                                <% } %>
                            </section>

                            <aside class="ha-detail-panel">
                                <div class="ha-panel">
                                    <h2 class="ha-panel-title">Details</h2>
                                    <dl class="ha-specs">
                                        <div class="ha-spec">
                                            <dt>Category</dt>
                                            <dd><%= vehicle.category?.name %></dd>
                                        </div>
                                        <div class="ha-spec">
                                            <dt>Year</dt>
                                            <dd><%= vehicle.year %></dd>
                                        </div>
                                        <div class="ha-spec">
                                            <dt>Make</dt>
                                            <dd><%= vehicle.make %></dd>
                                        </div>
                                        <div class="ha-spec">
                                            <dt>Model</dt>
                                            <dd><%= vehicle.model %></dd>
                                        </div>
                                        <div class="ha-spec">
                                            <dt>Mileage</dt>
                                            <dd>
                                                <% if (vehicle.mileage !== null && vehicle.mileage !== undefined) { %>
                                                    <%= Number(vehicle.mileage).toLocaleString() %> miles
                                                <% } else { %>
                                                    —
                                                <% } %>
                                            </dd>
                                        </div>
                                    </dl>
                                </div>

                                <div class="ha-panel">
                                    <h2 class="ha-panel-title">Description</h2>
                                    <p class="ha-panel-body">
                                        <%= vehicle.description || 'No description provided yet.' %>
                                    </p>
                                </div>

                                <div class="ha-panel ha-reviews-panel">
                                    <div class="ha-review-panel-header">
                                        <h2 class="ha-panel-title">Reviews</h2>
                                        <% if (currentUser && !userReview) { %>
                                            <a
                                                href="/vehicles/<%= vehicle.id %>/reviews/new"
                                                class="ha-button ha-button-ghost ha-button-sm ha-review-compose-trigger"
                                                aria-label="Write a review"
                                                >+</a
                                            >
                                        <% } %>
                                    </div>

                                    <% if (reviews && reviews.length) { %>
                                        <ul class="ha-review-list">
                                            <% reviews.forEach((rev) => { %>
                                                <% const isAuthor = currentUser && currentUser.id === rev.user_id; %>
                                                <% const isStaff =
                                                    currentUser &&
                                                    (currentUser.role === 'employee' || currentUser.role === 'owner'); %>
                                                <li class="ha-review-item">
                                                    <div class="ha-review-item-header">
                                                        <span class="ha-review-stars" aria-label="<%= rev.rating %> out of 5 stars">
                                                            <% for (let s = 1; s <= 5; s++) { %>
                                                                <%= s <= rev.rating ? '★' : '☆' %>
                                                            <% } %>
                                                        </span>
                                                        <span class="ha-review-meta">
                                                            <span class="ha-review-author"><%= rev.author_name %></span>
                                                            <span class="ha-meta-sep">•</span>
                                                            <time datetime="<%= new Date(rev.created_at).toISOString() %>">
                                                                <%= new Date(rev.created_at).toLocaleDateString(undefined, {
                                                                    year: 'numeric',
                                                                    month: 'short',
                                                                    day: 'numeric'
                                                                }) %>
                                                            </time>
                                                        </span>
                                                    </div>
                                                    <p class="ha-review-body"><%= rev.body %></p>
                                                    <% if (isAuthor || isStaff) { %>
                                                        <div class="ha-review-actions">
                                                            <% if (isAuthor) { %>
                                                                <a
                                                                    href="/vehicles/<%= vehicle.id %>/reviews/<%= rev.id %>/edit"
                                                                    class="ha-button ha-button-ghost ha-button-sm"
                                                                    >Edit</a
                                                                >
                                                            <% } %>
                                                            <form
                                                                method="post"
                                                                action="/vehicles/<%= vehicle.id %>/reviews/<%= rev.id %>/delete"
                                                                class="ha-inline-form"
                                                            >
                                                                <button type="submit" class="ha-button ha-button-ghost ha-button-sm ha-button-danger-ghost">
                                                                    <%= isStaff && !isAuthor ? 'Remove' : 'Delete' %>
                                                                </button>
                                                            </form>
                                                        </div>
                                                    <% } %>
                                                </li>
                                            <% }); %>
                                        </ul>
                                    <% } else { %>
                                        <p class="ha-panel-body ha-review-empty">No reviews yet.</p>
                                    <% } %>

                                    <% if (currentUser) { %>
                                        <% if (userReview) { %>
                                            <p class="ha-panel-body ha-review-own-note">
                                                You’ve reviewed this vehicle.
                                                <a href="/vehicles/<%= vehicle.id %>/reviews/<%= userReview.id %>/edit">Edit your review</a>
                                            </p>
                                        <% } %>
                                    <% } else { %>
                                        <p class="ha-panel-body ha-review-login-hint">
                                            <a href="/auth/login">Log in</a> or <a href="/auth/register">register</a> to leave a review.
                                        </p>
                                    <% } %>
                                </div>
                            </aside>
                        </div>

                        <div class="ha-page-actions">
                            <a href="/vehicles" class="ha-button ha-button-ghost">Back to browse</a>
                        </div>
                    </div>
                </section>
            </main>

            <footer class="ha-footer">
                <div class="ha-footer-inner">
                    <%- include('../partials/footer') %>
                </div>
            </footer>
        </div>
    </body>
</html>
