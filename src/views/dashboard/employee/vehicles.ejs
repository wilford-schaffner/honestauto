<%- include('../../layouts/app-start') %>
                <section class="ha-page">
                    <div class="ha-page-inner">
                        <div class="ha-page-heading ha-page-heading-inline">
                            <div>
                                <h1 class="ha-page-title">Vehicles</h1>
                                <p class="ha-page-body">Employees can update price, description, and availability.</p>
                            </div>
                            <div class="ha-page-actions">
                                <a href="/dashboard/employee" class="ha-button ha-button-ghost">Back</a>
                            </div>
                        </div>
                        <% if (!vehicles || vehicles.length === 0) { %>
                            <div class="ha-empty">
                                <h3 class="ha-empty-title">No Vehicles Found.</h3>
                                <p class="ha-empty-body">Inventory vehicles will appear here when available.</p>
                            </div>
                        <% } else { %>
                            <ul class="ha-review-list">
                                <% vehicles.forEach((vehicle) => { %>
                                    <li class="ha-review-item ha-review-item-spacious">
                                        <div class="ha-review-item-header">
                                            <span class="ha-review-author">
                                                <%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %>
                                            </span>
                                            <span class="ha-review-meta">
                                                <%= vehicle.category?.name %>
                                                <span class="ha-meta-sep">•</span>
                                                $<%= Number(vehicle.price).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                                                <span class="ha-meta-sep">•</span>
                                                <span class="<%= vehicle.available ? 'ha-status-available' : 'ha-status-unavailable' %>">
                                                    <%= vehicle.available ? 'Available' : 'Unavailable' %>
                                                </span>
                                            </span>
                                        </div>
                                        <div class="ha-review-actions">
                                            <a href="/dashboard/employee/vehicles/<%= vehicle.id %>/edit" class="ha-button ha-button-ghost ha-button-sm">Edit</a>
                                            <a href="/vehicles/<%= vehicle.id %>" class="ha-button ha-button-ghost ha-button-sm">View public page</a>
                                        </div>
                                    </li>
                                <% }); %>
                            </ul>
                        <% } %>
                    </div>
                </section>
<%- include('../../layouts/app-main-footer') %>
<%- include('../../layouts/app-doc-end') %>
