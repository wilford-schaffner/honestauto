<%- include('../layouts/app-start') %>
                <section class="ha-page">
                    <div class="ha-page-inner">
                        <h1 class="ha-page-title">Create Your Account</h1>
                        <p class="ha-page-body">
                            Register as a standard user to leave reviews and track service requests.
                        </p>

                        <form method="post" action="/auth/register" class="ha-form" novalidate>
                            <div class="ha-field">
                                <label class="ha-label" for="name">Name</label>
                                <input
                                    class="ha-input <%= fieldErrors?.name ? 'ha-input-error' : '' %>"
                                    type="text"
                                    id="name"
                                    name="name"
                                    value="<%= form?.name || '' %>"
                                    autocomplete="name"
                                    required
                                />
                                <% if (fieldErrors?.name) { %>
                                    <p class="ha-field-error"><%= fieldErrors.name %></p>
                                <% } %>
                            </div>

                            <div class="ha-field">
                                <label class="ha-label" for="email">Email</label>
                                <input
                                    class="ha-input <%= fieldErrors?.email ? 'ha-input-error' : '' %>"
                                    type="email"
                                    id="email"
                                    name="email"
                                    value="<%= form?.email || '' %>"
                                    autocomplete="email"
                                    required
                                />
                                <% if (fieldErrors?.email) { %>
                                    <p class="ha-field-error"><%= fieldErrors.email %></p>
                                <% } %>
                            </div>

                            <div class="ha-form-grid">
                                <div class="ha-field">
                                    <label class="ha-label" for="password">Password</label>
                                    <input
                                        class="ha-input <%= fieldErrors?.password ? 'ha-input-error' : '' %>"
                                        type="password"
                                        id="password"
                                        name="password"
                                        autocomplete="new-password"
                                        required
                                    />
                                    <% if (fieldErrors?.password) { %>
                                        <p class="ha-field-error"><%= fieldErrors.password %></p>
                                    <% } %>
                                </div>

                                <div class="ha-field">
                                    <label class="ha-label" for="confirmPassword">Confirm password</label>
                                    <input
                                        class="ha-input <%= fieldErrors?.confirmPassword ? 'ha-input-error' : '' %>"
                                        type="password"
                                        id="confirmPassword"
                                        name="confirmPassword"
                                        autocomplete="new-password"
                                        required
                                    />
                                    <% if (fieldErrors?.confirmPassword) { %>
                                        <p class="ha-field-error"><%= fieldErrors.confirmPassword %></p>
                                    <% } %>
                                </div>
                            </div>

                            <% if (error) { %>
                                <p class="ha-field-error"><%= error %></p>
                            <% } %>

                            <div class="ha-page-actions">
                                <button type="submit" class="ha-button ha-button-primary">Create Account</button>
                                <a href="/auth/login" class="ha-button ha-button-ghost">Already have an account?</a>
                            </div>
                        </form>
                    </div>
                </section>
<%- include('../layouts/app-main-footer') %>
<%- include('../layouts/app-doc-end') %>
