<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title || 'Contact – Honest Auto' %></title>
        <link rel="stylesheet" href="/css/style.css" />
    </head>
    <body>
        <div class="ha-app">
            <header class="ha-header">
                <div class="ha-header-inner">
                    <%- include('../partials/header') %>
                    <%- include('../partials/nav') %>
                </div>
            </header>

            <main class="ha-main">
                <section class="ha-flash-region">
                    <%- include('../partials/flash') %>
                </section>

                <section class="ha-page">
                    <div class="ha-page-inner">
                        <h1 class="ha-page-title">Contact Honest Auto</h1>
                        <p class="ha-page-body">
                            Have a question about a vehicle or a service request? Send a message and we’ll reply
                            soon.
                        </p>

                        <form method="post" action="/contact" class="ha-form" novalidate>
                            <div class="ha-form-grid">
                                <div class="ha-field">
                                    <label class="ha-label" for="name">Name</label>
                                    <input
                                        class="ha-input <%= fieldErrors?.name ? 'ha-input-error' : '' %>"
                                        type="text"
                                        id="name"
                                        name="name"
                                        value="<%= form?.name || '' %>"
                                        autocomplete="name"
                                        required
                                    />
                                    <% if (fieldErrors?.name) { %>
                                        <p class="ha-field-error"><%= fieldErrors.name %></p>
                                    <% } %>
                                </div>

                                <div class="ha-field">
                                    <label class="ha-label" for="email">Email</label>
                                    <input
                                        class="ha-input <%= fieldErrors?.email ? 'ha-input-error' : '' %>"
                                        type="email"
                                        id="email"
                                        name="email"
                                        value="<%= form?.email || '' %>"
                                        autocomplete="email"
                                        required
                                    />
                                    <% if (fieldErrors?.email) { %>
                                        <p class="ha-field-error"><%= fieldErrors.email %></p>
                                    <% } %>
                                </div>
                            </div>

                            <div class="ha-field">
                                <label class="ha-label" for="subject">Subject</label>
                                <input
                                    class="ha-input <%= fieldErrors?.subject ? 'ha-input-error' : '' %>"
                                    type="text"
                                    id="subject"
                                    name="subject"
                                    value="<%= form?.subject || '' %>"
                                    required
                                />
                                <% if (fieldErrors?.subject) { %>
                                    <p class="ha-field-error"><%= fieldErrors.subject %></p>
                                <% } %>
                            </div>

                            <div class="ha-field">
                                <label class="ha-label" for="message">Message</label>
                                <textarea
                                    class="ha-textarea <%= fieldErrors?.message ? 'ha-input-error' : '' %>"
                                    id="message"
                                    name="message"
                                    rows="6"
                                    required
                                ><%= form?.message || '' %></textarea>
                                <% if (fieldErrors?.message) { %>
                                    <p class="ha-field-error"><%= fieldErrors.message %></p>
                                <% } %>
                            </div>

                            <div class="ha-page-actions">
                                <button type="submit" class="ha-button ha-button-primary">Send message</button>
                                <a href="/vehicles" class="ha-button ha-button-ghost">Browse Vehicles</a>
                            </div>
                        </form>
                    </div>
                </section>
            </main>

            <footer class="ha-footer">
                <div class="ha-footer-inner">
                    <%- include('../partials/footer') %>
                </div>
            </footer>
        </div>
    </body>
</html>
