<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title || 'Write review – Honest Auto' %></title>
        <link rel="stylesheet" href="/css/style.css" />
    </head>
    <body>
        <div class="ha-app">
            <header class="ha-header">
                <div class="ha-header-inner">
                    <%- include('../partials/header') %>
                    <%- include('../partials/nav') %>
                </div>
            </header>

            <main class="ha-main">
                <section class="ha-flash-region">
                    <%- include('../partials/flash') %>
                </section>

                <section class="ha-page">
                    <div class="ha-page-inner">
                        <div class="ha-page-heading">
                            <div>
                                <p class="ha-detail-kicker">Write a review</p>
                                <h1 class="ha-page-title">
                                    <%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %>
                                </h1>
                                <p class="ha-page-body ha-page-body-tight">
                                    Share your experience. Your review will appear on this vehicle’s detail page.
                                </p>
                            </div>
                        </div>

                        <% if (error) { %>
                            <p class="ha-field-error ha-review-form-banner"><%= error %></p>
                        <% } %>

                        <form method="post" action="/vehicles/<%= vehicle.id %>/reviews" class="ha-form" novalidate>
                            <div class="ha-field">
                                <label class="ha-label" for="new-review-rating">Rating</label>
                                <select
                                    class="ha-input <%= fieldErrors?.rating ? 'ha-input-error' : '' %>"
                                    id="new-review-rating"
                                    name="rating"
                                    required
                                >
                                    <% const r = form?.rating; %>
                                    <% const labels = ['', 'Poor', 'Fair', 'Good', 'Very good', 'Excellent']; %>
                                    <option value="" <%= !r ? 'selected' : '' %> disabled>Choose…</option>
                                    <% for (let n = 1; n <= 5; n++) { %>
                                        <option value="<%= n %>" <%= String(r) === String(n) ? 'selected' : '' %>>
                                            <%= n %> — <%= labels[n] %>
                                        </option>
                                    <% } %>
                                </select>
                                <% if (fieldErrors?.rating) { %>
                                    <p class="ha-field-error"><%= fieldErrors.rating %></p>
                                <% } %>
                            </div>

                            <div class="ha-field">
                                <label class="ha-label" for="new-review-body">Your review</label>
                                <textarea
                                    class="ha-textarea <%= fieldErrors?.body ? 'ha-input-error' : '' %>"
                                    id="new-review-body"
                                    name="body"
                                    rows="7"
                                    required
                                ><%= form?.body || '' %></textarea>
                                <% if (fieldErrors?.body) { %>
                                    <p class="ha-field-error"><%= fieldErrors.body %></p>
                                <% } %>
                            </div>

                            <div class="ha-page-actions">
                                <button type="submit" class="ha-button ha-button-primary">Post review</button>
                                <a href="/vehicles/<%= vehicle.id %>" class="ha-button ha-button-ghost">Cancel</a>
                            </div>
                        </form>
                    </div>
                </section>
            </main>

            <footer class="ha-footer">
                <div class="ha-footer-inner">
                    <%- include('../partials/footer') %>
                </div>
            </footer>
        </div>
    </body>
</html>

