<%- include('../layouts/app-start') %>
                <section class="ha-page">
                    <div class="ha-page-inner">
                        <div class="ha-page-heading">
                            <div>
                                <p class="ha-detail-kicker">Edit Review</p>
                                <h1 class="ha-page-title">
                                    <%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %>
                                </h1>
                                <p class="ha-page-body ha-page-body-tight">
                                    Update your rating and comments. Only you can edit this review.
                                </p>
                            </div>
                        </div>

                        <% if (error) { %>
                            <p class="ha-field-error ha-review-form-banner"><%= error %></p>
                        <% } %>

                        <form
                            method="post"
                            action="/vehicles/<%= vehicle.id %>/reviews/<%= review.id %>/update"
                            class="ha-form"
                            novalidate
                        >
                            <div class="ha-field">
                                <label class="ha-label" for="edit-review-rating">Rating</label>
                                <select
                                    class="ha-input <%= fieldErrors?.rating ? 'ha-input-error' : '' %>"
                                    id="edit-review-rating"
                                    name="rating"
                                    required
                                >
                                    <% const r = form?.rating; %>
                                    <% const labels = ['', 'Poor', 'Fair', 'Good', 'Very good', 'Excellent']; %>
                                    <option value="" <%= !r ? 'selected' : '' %> disabled>Choose…</option>
                                    <% for (let n = 1; n <= 5; n++) { %>
                                        <option value="<%= n %>" <%= String(r) === String(n) ? 'selected' : '' %>><%= n %> — <%= labels[n] %></option>
                                    <% } %>
                                </select>
                                <% if (fieldErrors?.rating) { %>
                                    <p class="ha-field-error"><%= fieldErrors.rating %></p>
                                <% } %>
                            </div>
                            <div class="ha-field">
                                <label class="ha-label" for="edit-review-body">Your review</label>
                                <textarea
                                    class="ha-textarea <%= fieldErrors?.body ? 'ha-input-error' : '' %>"
                                    id="edit-review-body"
                                    name="body"
                                    rows="6"
                                    required
                                ><%= form?.body || '' %></textarea>
                                <% if (fieldErrors?.body) { %>
                                    <p class="ha-field-error"><%= fieldErrors.body %></p>
                                <% } %>
                            </div>
                            <div class="ha-page-actions">
                                <button type="submit" class="ha-button ha-button-primary">Save changes</button>
                                <a href="/vehicles/<%= vehicle.id %>" class="ha-button ha-button-ghost">Cancel</a>
                            </div>
                        </form>
                    </div>
                </section>
<%- include('../layouts/app-main-footer') %>
<%- include('../layouts/app-doc-end') %>
