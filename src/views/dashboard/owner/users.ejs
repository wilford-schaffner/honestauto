<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title || 'Users – Honest Auto' %></title>
        <link rel="stylesheet" href="/css/style.css" />
    </head>
    <body>
        <div class="ha-app">
            <header class="ha-header"><div class="ha-header-inner"><%- include('../../partials/header') %><%- include('../../partials/nav') %></div></header>
            <main class="ha-main">
                <section class="ha-flash-region"><%- include('../../partials/flash') %></section>
                <section class="ha-page">
                    <div class="ha-page-inner">
                        <div class="ha-page-heading ha-page-heading-inline">
                            <h1 class="ha-page-title">Users</h1>
                            <div class="ha-page-actions">
                                <a href="/dashboard/owner" class="ha-button ha-button-ghost">Back</a>
                            </div>
                        </div>
                        <% if (!users || users.length === 0) { %>
                            <div class="ha-empty">
                                <h3 class="ha-empty-title">No Users Found.</h3>
                                <p class="ha-empty-body">Accounts will appear here after users register.</p>
                            </div>
                        <% } else { %>
                            <ul class="ha-review-list">
                                <% users.forEach((user) => { %>
                                    <li class="ha-review-item">
                                        <div class="ha-review-item-header">
                                            <span class="ha-review-author"><%= user.name %></span>
                                            <span class="ha-review-meta"><%= user.email %></span>
                                        </div>
                                        <form method="post" action="/dashboard/owner/users/<%= user.id %>/role" class="ha-review-actions">
                                            <select
                                                name="role"
                                                class="ha-input ha-user-role-select"
                                                aria-label="Role for <%= user.name %>"
                                                onchange="this.form.requestSubmit()"
                                            >
                                                <option value="<%= roles.USER %>" <%= user.role === roles.USER ? 'selected' : '' %>>User</option>
                                                <option value="<%= roles.EMPLOYEE %>" <%= user.role === roles.EMPLOYEE ? 'selected' : '' %>>Employee</option>
                                                <option value="<%= roles.OWNER %>" <%= user.role === roles.OWNER ? 'selected' : '' %>>Owner</option>
                                            </select>
                                        </form>
                                    </li>
                                <% }) %>
                            </ul>
                        <% } %>
                    </div>
                </section>
            </main>
            <footer class="ha-footer"><div class="ha-footer-inner"><%- include('../../partials/footer') %></div></footer>
        </div>
    </body>
</html>
