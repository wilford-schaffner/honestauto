<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title || 'Edit Vehicle – Honest Auto' %></title>
        <link rel="stylesheet" href="/css/style.css" />
    </head>
    <body>
        <div class="ha-app">
            <header class="ha-header">
                <div class="ha-header-inner">
                    <%- include('../../partials/header') %>
                    <%- include('../../partials/nav') %>
                </div>
            </header>
            <main class="ha-main">
                <section class="ha-flash-region"><%- include('../../partials/flash') %></section>
                <section class="ha-page">
                    <div class="ha-page-inner">
                        <h1 class="ha-page-title">Edit <%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %></h1>
                        <% if (error) { %><p class="ha-field-error"><%= error %></p><% } %>
                        <form method="post" action="/dashboard/employee/vehicles/<%= vehicle.id %>" class="ha-form">
                            <div class="ha-field">
                                <label class="ha-label" for="price">Price</label>
                                <input id="price" name="price" class="ha-input <%= fieldErrors.price ? 'ha-input-error' : '' %>" value="<%= form.price %>" />
                                <% if (fieldErrors.price) { %><p class="ha-field-error"><%= fieldErrors.price %></p><% } %>
                            </div>
                            <div class="ha-field">
                                <label class="ha-label" for="description">Description</label>
                                <textarea id="description" name="description" rows="6" class="ha-textarea <%= fieldErrors.description ? 'ha-input-error' : '' %>"><%= form.description %></textarea>
                                <% if (fieldErrors.description) { %><p class="ha-field-error"><%= fieldErrors.description %></p><% } %>
                            </div>
                            <div class="ha-field">
                                <label class="ha-label" for="available">Availability</label>
                                <select id="available" name="available" class="ha-input <%= fieldErrors.available ? 'ha-input-error' : '' %>">
                                    <option value="true" <%= form.available === 'true' ? 'selected' : '' %>>Available</option>
                                    <option value="false" <%= form.available === 'false' ? 'selected' : '' %>>Unavailable</option>
                                </select>
                                <% if (fieldErrors.available) { %><p class="ha-field-error"><%= fieldErrors.available %></p><% } %>
                            </div>
                            <div class="ha-page-actions">
                                <button type="submit" class="ha-button ha-button-primary">Save changes</button>
                                <a href="/dashboard/employee/vehicles" class="ha-button ha-button-ghost">Cancel</a>
                            </div>
                        </form>
                    </div>
                </section>
            </main>
            <footer class="ha-footer">
                <div class="ha-footer-inner"><%- include('../../partials/footer') %></div>
            </footer>
        </div>
    </body>
</html>
