<%- include('../../layouts/app-start') %>
                <section class="ha-page">
                    <div class="ha-page-inner">
                        <div class="ha-page-heading ha-page-heading-inline">
                            <h1 class="ha-page-title">Reviews</h1>
                            <div class="ha-page-actions">
                                <a
                                    href="<%= currentUser?.role === 'owner' ? '/dashboard/owner' : '/dashboard/employee' %>"
                                    class="ha-button ha-button-ghost"
                                    >Back</a
                                >
                            </div>
                        </div>
                        <% if (!reviews || reviews.length === 0) { %>
                            <div class="ha-empty">
                                <h3 class="ha-empty-title">No Reviews Found.</h3>
                                <p class="ha-empty-body">User reviews will appear here for moderation.</p>
                            </div>
                        <% } else { %>
                            <ul class="ha-review-list">
                                <% reviews.forEach((review) => { %>
                                    <li class="ha-review-item">
                                        <div class="ha-review-item-header">
                                            <span class="ha-review-author"><%= review.vehicle_year %> <%= review.vehicle_make %> <%= review.vehicle_model %></span>
                                            <span class="ha-review-meta">
                                                By <%= review.author_name %> <span class="ha-meta-sep">•</span> <%= review.rating %>/5
                                            </span>
                                        </div>
                                        <p class="ha-review-body"><%= review.body %></p>
                                        <div class="ha-review-actions">
                                            <a href="/vehicles/<%= review.vehicle_id %>" class="ha-button ha-button-ghost ha-button-sm">View vehicle</a>
                                            <form method="post" action="/dashboard/employee/reviews/<%= review.id %>/delete" class="ha-inline-form">
                                                <button type="submit" class="ha-button ha-button-danger-ghost ha-button-sm" onclick="return confirm('Remove this review?');">Remove</button>
                                            </form>
                                        </div>
                                    </li>
                                <% }) %>
                            </ul>
                        <% } %>
                    </div>
                </section>
<%- include('../../layouts/app-main-footer') %>
<%- include('../../layouts/app-doc-end') %>
